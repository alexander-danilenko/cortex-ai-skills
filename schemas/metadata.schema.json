{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alexander-danilenko/cortex-ai-skills/schemas/metadata.schema.json",
  "title": "Skill Metadata",
  "description": "Schema for cortex plugin skill metadata files",
  "type": "object",
  "required": ["authors", "license", "version"],
  "additionalProperties": false,
  "properties": {
    "authors": {
      "type": "array",
      "description": "GitHub profile URLs of skill authors",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^https://github\\.com/.+"
      }
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier",
      "enum": ["MIT", "Apache-2.0", "BSD-2-Clause", "BSD-3-Clause", "GPL-2.0-only", "GPL-3.0-only", "LGPL-2.1-only", "LGPL-3.0-only", "AGPL-3.0-only", "ISC", "Unlicense"]
    },
    "version": {
      "type": "string",
      "description": "Semantic version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "domain": {
      "type": "string",
      "description": "Skill category",
      "enum": [
        "accessibility",
        "ai-ml",
        "api-architecture",
        "backend",
        "cloud",
        "data-ml",
        "database",
        "design",
        "devops",
        "documentation",
        "frontend",
        "gamedev",
        "infrastructure",
        "language",
        "mobile",
        "observability",
        "performance",
        "quality",
        "security",
        "specialized",
        "testing",
        "workflow"
      ]
    },
    "triggers": {
      "type": "string",
      "description": "Comma-separated discovery keywords"
    },
    "role": {
      "type": "string",
      "description": "Primary expertise role",
      "enum": [
        "analyst",
        "architect",
        "consultant",
        "engineer",
        "expert",
        "lead",
        "reviewer",
        "specialist"
      ]
    },
    "scope": {
      "type": "string",
      "description": "Type of work the skill performs",
      "enum": [
        "analysis",
        "architecture",
        "debugging",
        "design",
        "documentation",
        "implementation",
        "infrastructure",
        "migration",
        "monitoring",
        "optimization",
        "planning",
        "refactoring",
        "review",
        "security",
        "system-design",
        "testing"
      ]
    },
    "output-format": {
      "type": "string",
      "description": "Primary output type",
      "enum": [
        "analysis-and-code",
        "architecture",
        "checklist",
        "code",
        "code+analysis",
        "config",
        "diagram",
        "document",
        "guide",
        "plan",
        "report",
        "specification",
        "template"
      ]
    },
    "related-skills": {
      "type": "array",
      "description": "References to related skills in this plugin",
      "items": {
        "type": "string",
        "enum": [
          "agents-md-pro",
          "api-designer",
          "architecture-designer",
          "cli-developer",
          "cloud-architect",
          "code-documenter",
          "code-reviewer",
          "csharp-developer",
          "database-optimizer",
          "devops-engineer",
          "dotnet-core-expert",
          "humanizer",
          "javascript-pro",
          "legacy-modernizer",
          "nestjs-expert",
          "nextjs-developer",
          "playwright-expert",
          "prompt-engineer",
          "python-pro",
          "rag-architect",
          "react-expert",
          "secure-code-guardian",
          "security-reviewer",
          "spec-miner",
          "sql-pro",
          "sre-engineer",
          "test-master",
          "typescript-pro"
        ]
      }
    }
  }
}
